# Environment Configuration
# Copy this file to .env and fill in your values

# ─── SERVER ────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── DATABASE ──────────────────────────────────────────
# MongoDB Connection String
# For local development: mongodb://localhost:27017/ammunition-log
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/ammunition-log
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ammunition-log?retryWrites=true&w=majority

# ─── FRONTEND ──────────────────────────────────────────
VITE_API_URL=/api
